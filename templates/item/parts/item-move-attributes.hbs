{{!-- Move Attributes Tab --}}
<section class="tab {{ tab.cssClass }}" data-tab="{{ tab.id }}" data-group="{{ tab.group }}">
  <div class="checkbox-pair-grid">
    <div class="form-group">
      <label class="resource-label">Typeless Maneuver?</label>
      <input type="checkbox" name="system.attributes.maneuver" {{checked system.attributes.maneuver}} data-dtype="Boolean">
    </div>
    <div class="form-group">
      <label class="resource-label">Lethal?</label>
      <input type="checkbox" name="system.attributes.lethal" {{checked system.attributes.lethal}} data-dtype="Boolean">
    </div>
    {{#if owned}}
    {{#unless system.attributes.maneuver}}
    <div class="form-group">
      <label class="resource-label">Learned?</label>
      <input type="checkbox" name="system.learned" {{checked system.learned}} data-dtype="Boolean">
    </div>
    {{#if system.learned}}
    <div class="form-group">
      <label class="resource-label">Overrank Move?</label>
      <input type="checkbox" name="system.overrank" {{checked system.overrank}} data-dtype="Boolean">
    </div>
    {{/if}}
    {{/unless}}
    {{/if}}
  </div>

  {{#if owned}}
  {{#unless system.attributes.maneuver}}
  {{#unless system.learned}}
  <div class="form-group">
    <label class="resource-label">Learned at Rank</label>
    <select name="system.rank" value="{{system.rank}}" data-dtype="String">
      {{selectOptions ranks selected=system.rank}}
    </select>
  </div>
  {{/unless}}
  {{/unless}}
  {{/if}}

  <hr>

  <h3>Move Data</h3>
  <div class="form-group">
    <label class="resource-label">Type</label>
    <select name="system.type" value="{{system.type}}" data-dtype="String">
      {{selectOptions types selected=system.type}}
    </select>
  </div>
  <div class="form-group">
    <label class="resource-label">Category</label>
    <select name="system.category" value="{{system.category}}" data-dtype="String">
      {{selectOptions categories selected=system.category}}
    </select>
  </div>
  <div class="form-group">
    <label class="resource-label">Target</label>
    <select name="system.target" value="{{system.target}}" data-dtype="String">
      {{selectOptions targets selected=system.target}}
    </select>
  </div>
  <div class="form-group">
    <label class="resource-label">Power</label>
    <input type="number" name="system.power" value="{{system.power}}" data-dtype="Number"/>
  </div>
  <div class="form-group alternative-stat">
    <label class="resource-label">Accuracy Modifiers (Attribute)</label>
    <input type="text" name="system.accAttr1" value="{{system.accAttr1}}" data-dtype="String">
    <label>/</label>
    <input type="text" name="system.accAttr1var" value="{{system.accAttr1var}}" data-dtype="String">
  </div>
  <div class="form-group alternative-stat">
    <label class="resource-label">Accuracy Modifiers (Skill)</label>
    <input type="text" name="system.accSkill1" value="{{system.accSkill1}}" data-dtype="String">
    <label>/</label>
    <input type="text" name="system.accSkill1var" value="{{system.accSkill1var}}" data-dtype="String">
  </div>
  <div class="form-group">
    <label class="resource-label">Accuracy Reduction</label>
    <input type="number" name="system.attributes.accuracyReduction" value="{{system.attributes.accuracyReduction}}" data-dtype="Number"/>
  </div>
  <div class="form-group alternative-stat">
    <label class="resource-label">Damage Modifiers</label>
    <input type="text" name="system.dmgMod1" value="{{system.dmgMod1}}" data-dtype="String">
    <label>/</label>
    <input type="text" name="system.dmgMod1var" value="{{system.dmgMod1var}}" data-dtype="String">
  </div>
  <div class="form-group">
    <label class="resource-label">Added Effect</label>
    <textarea name="system.effect" data-dtype="String" {{#unless editable}}readonly{{/unless}}>{{system.effect}}</textarea>
  </div>

  {{!-- Damage Pool Formula - placed right below Added Effect so the description above explains
        why a move needs one of these before the reader reaches the fields that implement it. --}}
  <h3>Damage Pool Formula</h3>
  <div class="form-group">
    <label class="resource-label">Formula</label>
    <select name="system.damagePool.formula" value="{{system.damagePool.formula}}" data-dtype="String">
      {{selectOptions damagePoolFormulas selected=system.damagePool.formula}}
    </select>
  </div>

  {{#if isHpBased}}
  <div class="form-group">
    <label class="resource-label">HP Source</label>
    <select name="system.damagePool.hpMode" value="{{system.damagePool.hpMode}}" data-dtype="String">
      {{selectOptions damagePoolHpModes selected=system.damagePool.hpMode}}
    </select>
  </div>
  <div class="form-group">
    <label class="resource-label">Fraction (%, rounded down)</label>
    <input type="number" name="system.damagePool.fraction" value="{{system.damagePool.fraction}}" min="0" max="100" data-dtype="Number"/>
  </div>
  <div class="form-group">
    <label class="resource-label">Plus Amount</label>
    <input type="number" name="system.damagePool.plusAmount" value="{{system.damagePool.plusAmount}}" data-dtype="Number"/>
  </div>
  <div class="form-group">
    <label class="resource-label">Result</label>
    <select name="system.damagePool.resultAs" value="{{system.damagePool.resultAs}}" data-dtype="String">
      {{selectOptions damagePoolResultAs selected=system.damagePool.resultAs}}
    </select>
  </div>
  {{#if isDicePool}}
  <div class="form-group">
    <label class="resource-label">Dice Mode</label>
    <select name="system.damagePool.diceMode" value="{{system.damagePool.diceMode}}" data-dtype="String">
      {{selectOptions damagePoolDiceModes selected=system.damagePool.diceMode}}
    </select>
  </div>
  {{/if}}
  {{/if}}

  {{#if isStatDiff}}
  <div class="form-group">
    <label class="resource-label">Stat</label>
    <select name="system.damagePool.stat" value="{{system.damagePool.stat}}" data-dtype="String">
      {{selectOptions damagePoolStats selected=system.damagePool.stat}}
    </select>
  </div>
  {{#if isRankStat}}
  <div class="form-group">
    <label class="resource-label">Rank Table</label>
    <input type="text" name="system.damagePool.rankTable" value="{{system.damagePool.rankTable}}" data-dtype="String"/>
  </div>
  {{else}}
  <div class="form-group">
    <label class="resource-label">Direction</label>
    <select name="system.damagePool.direction" value="{{system.damagePool.direction}}" data-dtype="String">
      {{selectOptions damagePoolDirections selected=system.damagePool.direction}}
    </select>
  </div>
  <div class="form-group">
    <label class="resource-label">Dice Per Unit</label>
    <input type="number" name="system.damagePool.perUnit" value="{{system.damagePool.perUnit}}" min="0" data-dtype="Number"/>
  </div>
  {{/if}}
  <div class="form-group">
    <label class="resource-label">Dice Mode</label>
    <select name="system.damagePool.diceMode" value="{{system.damagePool.diceMode}}" data-dtype="String">
      {{selectOptions damagePoolDiceModes selected=system.damagePool.diceMode}}
    </select>
  </div>
  {{/if}}

  {{#if (or isHpBased isStatDiff)}}
  <div class="form-group">
    <label class="resource-label">Max Dice (blank = no cap)</label>
    <input type="number" name="system.damagePool.maxDice" value="{{system.damagePool.maxDice}}" min="0" data-dtype="Number"/>
  </div>
  {{/if}}

  {{#if isFixedDamagePool}}
  <div class="form-group">
    <label class="resource-label">Fixed Damage Amount</label>
    <input type="number" name="system.damagePool.amount" value="{{system.damagePool.amount}}" min="0" data-dtype="Number"/>
  </div>
  <div class="form-group">
    <label class="resource-label">Ignore Type Effectiveness</label>
    <input type="checkbox" name="system.damagePool.ignoreTypeEffectiveness" {{checked system.damagePool.ignoreTypeEffectiveness}} data-dtype="Boolean">
  </div>
  {{/if}}

  <hr>

  <h3>Reactions</h3>
  <div class="form-group alternative-stat">
    <label class="resource-label">React. / Late React.</label>
    <input type="number" name="system.attributes.reactionMove" value="{{system.attributes.reactionMove}}" data-dtype="Number"/>
    <label>/</label>
    <input type="number" name="system.attributes.lateReactionMove" value="{{system.attributes.lateReactionMove}}" data-dtype="Number"/>
  </div>

  <h3>Turn/Action Economy</h3>
  <div class="flag-grid">
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.charge" {{checked system.attributes.charge}} data-dtype="Boolean"> Charge</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.mustRecharge" {{checked system.attributes.mustRecharge}} data-dtype="Boolean"> Must Recharge</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.doubleAction" {{checked system.attributes.doubleAction}} data-dtype="Boolean"> Double Action</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.tripleAction" {{checked system.attributes.tripleAction}} data-dtype="Boolean"> Triple Action</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.successiveActions" {{checked system.attributes.successiveActions}} data-dtype="Boolean"> Successive Actions</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.unlimitedUses" {{checked system.attributes.unlimitedUses}} data-dtype="Boolean"> Unlimited Uses</label>
  </div>

  <h3>Combat Resolution</h3>
  <div class="flag-grid">
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.neverFail" {{checked system.attributes.neverFail}} data-dtype="Boolean"> Never Fail</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.highCritical" {{checked system.attributes.highCritical}} data-dtype="Boolean"> High Critical</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.alwaysCrit" {{checked system.attributes.alwaysCrit}} data-dtype="Boolean"> Always Crit</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.ignoreDefenses" {{checked system.attributes.ignoreDefenses}} data-dtype="Boolean"> Ignore Defenses</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.resistedWithDefense" {{checked system.attributes.resistedWithDefense}} data-dtype="Boolean"> Resisted With Defense</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.recoil" {{checked system.attributes.recoil}} data-dtype="Boolean"> Recoil</label>
  </div>

  <h3>Move Type Tags</h3>
  <div class="flag-grid">
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.fistBased" {{checked system.attributes.fistBased}} data-dtype="Boolean"> Fist Based</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.soundBased" {{checked system.attributes.soundBased}} data-dtype="Boolean"> Sound Based</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.cutterMove" {{checked system.attributes.cutterMove}} data-dtype="Boolean"> Cutter Move</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.windMove" {{checked system.attributes.windMove}} data-dtype="Boolean"> Wind Move</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.biteMove" {{checked system.attributes.biteMove}} data-dtype="Boolean"> Bite Move</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.powderMove" {{checked system.attributes.powderMove}} data-dtype="Boolean"> Powder Move</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.physicalRanged" {{checked system.attributes.physicalRanged}} data-dtype="Boolean"> Physical Ranged</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.projectileMove" {{checked system.attributes.projectileMove}} data-dtype="Boolean"> Projectile Move</label>
  </div>

  <h3>Field &amp; Special Conditions</h3>
  <div class="flag-grid">
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.shieldMove" {{checked system.attributes.shieldMove}} data-dtype="Boolean"> Shield Move</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.destroyShield" {{checked system.attributes.destroyShield}} data-dtype="Boolean"> Destroy Shield</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.resetTerrain" {{checked system.attributes.resetTerrain}} data-dtype="Boolean"> Reset Terrain</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.rampage" {{checked system.attributes.rampage}} data-dtype="Boolean"> Rampage</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.switcherMove" {{checked system.attributes.switcherMove}} data-dtype="Boolean"> Switcher Move</label>
    <label class="flag-checkbox"><input type="checkbox" name="system.attributes.userFaints" {{checked system.attributes.userFaints}} data-dtype="Boolean"> User Faints</label>
  </div>

  <hr>

  {{!-- Heal --}}
  <h3>HP Heal</h3>

  <div class="form-group">
    <label class="resource-label">Heal Type</label>
    <select name="system.heal.type" value="{{system.heal.type}}" data-dtype="String">
      {{selectOptions healTypes selected=system.heal.type}}
    </select>
  </div>

  {{#if healEnabled}}
  {{#unless isLeechHeal}}
  <div class="form-group">
    <label class="resource-label">Target</label>
    <select name="system.heal.target" value="{{system.heal.target}}" data-dtype="String">
      {{selectOptions effectTargets selected=system.heal.target}}
    </select>
  </div>

  <div class="form-group">
    <label class="resource-label">Will Point Cost</label>
    <input type="number" name="system.heal.willPointCost" value="{{system.heal.willPointCost}}" data-dtype="Number"/>
  </div>
  {{/unless}}
  {{/if}}

  {{#if isCustomHeal}}
  <div class="form-group">
    <label class="resource-label">Healed HP</label>
    <input type="number" name="system.heal.amount" value="{{system.heal.amount}}" data-dtype="Number"/>
  </div>
  {{/if}}

  {{#if isLeechHeal}}
  <div class="form-group">
    <label class="resource-label">Leech Percentage (0.0 - 1.0)</label>
    <input type="number" name="system.heal.amount" value="{{system.heal.amount}}" data-dtype="Number" min="0" max="1"/>
  </div>
  {{/if}}

  <hr>

  <div class="form-group">
    <label class="resource-label">Source</label>
    <input type="text" name="system.source" value="{{system.source}}" data-dtype="String"/>
  </div>
</section>
