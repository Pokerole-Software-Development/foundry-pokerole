{"_id": "6da49f8bcc3db754", "name": "Shiny Stone", "type": "item", "img": "systems/pokerole/images/items/shiny-stone.png", "system": {"description": "<p>Its polished surface allows you to see a ball of light inside. Rare to find, considered a good luck charm.</p>", "price": 10000, "rarity": "", "pocket": "evolutionItem"}, "effects": [], "source": "Core 3.0", "flags": {}, "_stats": {"systemId": "pokerole", "systemVersion": "v3.0", "coreVersion": "3.348", "createdTime": 1670695293664, "modifiedTime": 1784006565.05939, "lastModifiedBy": "Generator"}}
{"_id": "80755511cf134f02", "name": "Silk Scarf", "type": "item", "img": "systems/pokerole/images/items/silk-scarf.png", "system": {"description": "<p>A basic scarf, simple, but fashionable. Add 1 Extra die to the Damage pool of Normal-Type Moves.</p>", "price": null, "rarity": "Not for Sale", "pocket": "heldItem"}, "effects": [], "source": "Core 3.0", "flags": {}, "_stats": {"systemId": "pokerole", "systemVersion": "v3.0", "coreVersion": "3.348", "createdTime": 1670695293664, "modifiedTime": 1784006565.067503, "lastModifiedBy": "Generator"}}
{"_id": "2ec7767c6cfc211f", "name": "Silver Powder", "type": "item", "img": "systems/pokerole/images/items/silver-powder.png", "system": {"description": "<p>An itchy powder that induces allergies. Add 1 Extra die to the Damage pool of Bug-Type Moves.</p>", "price": null, "rarity": "Not for Sale", "pocket": "heldItem"}, "effects": [], "source": "Core 3.0", "flags": {}, "_stats": {"systemId": "pokerole", "systemVersion": "v3.0", "coreVersion": "3.348", "createdTime": 1670695293664, "modifiedTime": 1784006565.076067, "lastModifiedBy": "Generator"}}
{"_id": "36767448f27f3beb", "name": "Sitrus Berry", "type": "item", "img": "systems/pokerole/images/items/sitrus-berry.png", "system": {"description": "<p>A bigger berry from the Oran family but scarcer in the wild. It can also heal up to 1 Lethal Damage.</p>", "price": null, "rarity": "Rare", "pocket": "medicine"}, "effects": [], "source": "Core 3.0", "flags": {}, "_stats": {"systemId": "pokerole", "systemVersion": "v3.0", "coreVersion": "3.348", "createdTime": 1670695293664, "modifiedTime": 1784006565.084333, "lastModifiedBy": "Generator"}}
