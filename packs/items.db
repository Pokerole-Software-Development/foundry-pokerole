{"_id": "d3a2c5eceb92bad7", "name": "Heavy Ball", "type": "item", "img": "icons/svg/item-bag.svg", "system": {"description": "<p>Uncommon. Increase seal potency by 1 for every 50 lbs/25kg, on the Pokémon you are trying to catch. Up to 5 dice may be added this way.</p>", "price": null, "rarity": "Not for Sale", "pocket": "pokeball"}, "effects": [], "source": "Core 3.0", "flags": {}, "_stats": {"systemId": "pokerole", "systemVersion": "v3.0", "coreVersion": "3.348", "createdTime": 1670695293664, "modifiedTime": 1784006564.148107, "lastModifiedBy": "Generator"}}
