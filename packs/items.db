{"_id": "f3af5da6d12188d6", "name": "Saddle", "type": "item", "img": "icons/svg/item-bag.svg", "system": {"description": "<p>A secure seat to strap on a Pokémon large enough to carry you. Riding a Pokémon sure is exciting!</p>", "price": 500, "rarity": "", "pocket": "item"}, "effects": [], "source": "Core 3.0", "flags": {}, "_stats": {"systemId": "pokerole", "systemVersion": "v3.0", "coreVersion": "3.348", "createdTime": 1670695293664, "modifiedTime": 1784006564.999879, "lastModifiedBy": "Generator"}}
{"_id": "6c39474904e94cc3", "name": "Safety Goggles", "type": "item", "img": "systems/pokerole/images/items/safety-goggles.png", "system": {"description": "<p>No more pesky allergies. The user is immune to the Added Effects of Moves with the words \"Spore\", \"Powder\" & \"Pollen\".</p>", "price": null, "rarity": "Not for Sale", "pocket": "heldItem"}, "effects": [], "source": "Core 3.0", "flags": {}, "_stats": {"systemId": "pokerole", "systemVersion": "v3.0", "coreVersion": "3.348", "createdTime": 1670695293664, "modifiedTime": 1784006565.008572, "lastModifiedBy": "Generator"}}
