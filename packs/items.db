{"_id": "93aaaaec0cf4e289", "name": "Sharp Beak", "type": "item", "img": "systems/pokerole/images/items/sharp-beak.png", "system": {"description": "<p>A sharp metal cover to reinforce beaks. Add 1 Extra die to the Damage pool of Flying-Type Moves.</p>", "price": null, "rarity": "Not for Sale", "pocket": "heldItem"}, "effects": [], "source": "Core 3.0", "flags": {}, "_stats": {"systemId": "pokerole", "systemVersion": "v3.0", "coreVersion": "3.348", "createdTime": 1670695293664, "modifiedTime": 1784006565.042381, "lastModifiedBy": "Generator"}}
